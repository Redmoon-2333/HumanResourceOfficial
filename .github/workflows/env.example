# ============================================================
# GitHub Actions 环境变量配置说明
# ============================================================
# 此文件用于说明在 GitHub 仓库 Settings -> Secrets and variables -> Actions
# 中需要配置的 Secrets 和 Variables
# ============================================================

# ===================
# Required Secrets (必需的秘密)
# ===================

# Docker Hub 用户名
DOCKER_USERNAME=your_docker_hub_username

# Docker Hub Personal Access Token (不是密码!)
# 获取方式：https://hub.docker.com/settings/security -> New Access Token
DOCKER_PASSWORD=your_docker_hub_personal_access_token

# ===================
# Optional Secrets (可选的秘密)
# ===================

# 阿里云 OSS 配置 (如果使用 OSS 存储)
ALIYUN_OSS_ACCESS_KEY_ID=your_oss_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
ALIYUN_OSS_BUCKET_NAME=your_bucket_name

# ECNU AI API 配置
CHATECNU_API_KEY=your_chatecnu_api_key

# ===================
# Variables (变量，可选)
# ===================

# 镜像仓库名称
IMAGE_NAME=redmoon-2333/humanresourceofficial

# 默认 Docker Registry
DOCKER_REGISTRY=docker.io

# ===================
# 配置步骤
# ===================

# 1. 进入 GitHub 仓库页面
# 2. 点击 Settings 标签
# 3. 左侧菜单选择 Secrets and variables -> Actions
# 4. 在 Secrets 部分点击 "New repository secret"
# 5. 添加上述 Secrets
# 6. 保存后，GitHub Actions 工作流将自动使用这些秘密

# ===================
# 安全提示
# ===================

# ⚠️ 重要:
# 1. 不要在代码中硬编码敏感信息
# 2. 不要在 commit 历史记录中泄露 Secrets
# 3. 定期轮换 Access Tokens
# 4. 为不同环境使用不同的 Secrets
# 5. 限制 Access Token 的权限范围