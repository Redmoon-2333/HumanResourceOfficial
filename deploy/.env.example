# ============================================================
# 人力资源中心官网 - 环境变量配置模板
# 使用方法: 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================================

# ---------- 必填配置 ----------

# 数据库密码（MySQL root 密码，同时用于应用连接）
DB_PASSWORD=

# JWT 密钥（生产环境必须设置，至少 256 位用于 HS256 算法）
JWT_SECRET=

# ECNU AI API Key（华东师范大学 AI 平台密钥）
CHATECNU_API_KEY=

# ---------- Docker 镜像配置 ----------

# 后端 Docker 镜像（从 Docker Hub 拉取）
# DOCKER_IMAGE=redmoon2333/hrofficial-backend:latest

# ---------- RAG 知识库配置 ----------

# 宿主机上知识库目录路径（Docker 挂载用）
# 默认: ./rag-knowledge-base（当前目录下的 rag-knowledge-base 文件夹）
# 服务器部署示例: /home/hrofficial/hrofficial-deploy/rag-knowledge-base
RAG_KB_HOST_PATH=/home/hrofficial/hrofficial-deploy/rag-knowledge-base

# 容器内知识库路径（一般不需要修改，不要加 file: 前缀）
# RAG_KB_PATH=/app/rag-knowledge-base

# ---------- 上传文件配置 ----------

# 宿主机上上传文件目录路径（Docker 挂载用，Nginx 需要读取此目录）
# 默认: ./uploads
UPLOADS_HOST_PATH=/home/hrofficial/hrofficial-deploy/uploads

# ---------- 可选配置（有默认值）----------

# 数据库连接 URL（默认: localhost:3306/hrofficial）
# DB_URL=jdbc:mysql://localhost:3306/hrofficial?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# 数据库用户名（默认: root）
# DB_USERNAME=root

# ECNU AI Base URL（默认: https://chat.ecnu.edu.cn/open/api）
# CHATECNU_BASE_URL=https://chat.ecnu.edu.cn/open/api

# AI 工具调用模型（默认: ecnu-max）
# AI_TOOL_MODEL=ecnu-max

# JWT 过期时间（毫秒，默认: 604800000 = 7天）
# JWT_EXPIRATION=604800000

# Redis 配置（默认: localhost:6379 无密码）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=RedMoon

# 阿里云 OSS 配置（不配置则使用本地文件存储）
# ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET_NAME=

# 文件访问基础 URL（默认: http://81.70.218.85:3000）
# FILE_ACCESS_URL=http://81.70.218.85:3000
