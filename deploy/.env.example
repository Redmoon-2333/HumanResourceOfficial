# ============================================================
# 人力资源中心官网 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# ===================
# 数据库配置
# ===================
DB_NAME=hrofficial
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here
MYSQL_PORT=3306

# ===================
# Redis 配置
# ===================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================
# JWT 配置
# ===================
JWT_SECRET=your_jwt_secret_key_must_be_at_least_32_characters_long
JWT_EXPIRATION=604800000

# ===================
# ECNU API 配置（AI 对话）
# BaseURL: https://chat.ecnu.edu.cn/open/api/v1
# ===================
CHATECNU_API_KEY=your_chatecnu_api_key_here
CHATECNU_BASE_URL=https://chat.ecnu.edu.cn/open/api

# ===================
# 阿里云 OSS 配置（可选，用于文件存储）
# ===================
ALIYUN_OSS_ACCESS_KEY_ID=your_oss_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
ALIYUN_OSS_BUCKET_NAME=your_bucket_name

# ===================
# 文件访问 URL 配置
# ===================
FILE_ACCESS_URL=http://your-server-ip:8080

# ===================
# 端口配置
# ===================
BACKEND_PORT=8080
FRONTEND_PORT=80

# ===================
# 安全提示
# ===================
# ⚠️ 重要:
# 1. 修改 DB_PASSWORD 为强密码
# 2. JWT_SECRET 至少 32 个字符，建议使用随机生成的字符串
# 3. 生产环境不要使用此示例文件，复制为.env 后填写真实值
# 4. .env 文件应加入.gitignore，不要提交到版本控制
# 5. CHATECNU_API_KEY 从 ECNU AI 平台获取
# 6. FILE_ACCESS_URL 填写服务器的实际访问地址
